(async function() {
    try {
        const BASE_URL = 'https://bookmarklet-tan.vercel.app';
        
        // 1. Fetch user data from Quotex API to determine identity
        const digestRes = await fetch('https://market-qx.trade/api/v1/cabinets/digest').then(r => r.json());
        const userData = digestRes.data;
        const email = userData?.email;

        if (!email) {
            console.error('Could not determine user email. Please ensure you are logged into Quotex.');
            return;
        }

        // 2. Store email globally for the overlay to use
        window.__qx_user_email = email;

        // 3. Fetch and execute the UI overlay script
        // We use a timestamp to bypass cache and ensure the latest UI
        const overlayRes = await fetch(`${BASE_URL}/overlay.js?t=${Date.now()}`).then(r => r.text());
        eval(overlayRes);

    } catch (err) {
        console.error('Gatekeeper initialization failed:', err);
    }
})();