(async function() {
    try {
        const BASE_URL = 'https://qx-bookmarklet.vercel.app';
        
        // 1. Fetch user data from Quotex API
        const digestRes = await fetch('https://market-qx.trade/api/v1/cabinets/digest').then(r => r.json());
        const userData = digestRes.data;
        const email = userData?.email;

        if (!email) {
            console.error('Could not determine user email. Please ensure you are logged into Quotex.');
            return;
        }

        // 2. Verify authorization with Vercel Backend
        const authRes = await fetch(`${BASE_URL}/api/auth?email=${encodeURIComponent(email)}`).then(r => r.json());

        if (!authRes.authorized) {
            if (authRes.errorOverlay) eval(authRes.errorOverlay);
            return;
        }

        // 3. Load and show the configuration overlay
        // We fetch the overlay script and execute it
        const overlayScript = await fetch(`${BASE_URL}${authRes.overlayUrl}?t=${Date.now()}`).then(r => r.text());
        await eval(overlayScript);

        // 4. If overlay was saved/resolved, fetch and execute the main engine
        const engineScript = await fetch(`${BASE_URL}${authRes.engineUrl}?email=${encodeURIComponent(email)}&t=${Date.now()}`).then(r => r.text());
        eval(engineScript);

    } catch (err) {
        console.error('Bookmarklet initialization failed:', err);
    }
})();